# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
.buildenv/

# Build / package outputs (transient). build/recipe/ is source — it's the
# python-appimage recipe consumed by build.sh, so keep that one.
build/*
!build/recipe/
!build/recipe/**
dist/
release/
*.spec
cove_icon.ico

# Local cove runtime state (only relevant when running from the source tree)
cove/cove_icon.png
cove/Archive.zip

# Chrome extension signing key (private — NEVER commit). The public key is
# pinned in extension/manifest.chrome.json; this .pem must stay local.
extension/chrome-key.pem
*.pem

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
AGENTS.md
.claudeignore

.codex-reviews/

# Session aids (orientation snapshots)
*-orientation.md
